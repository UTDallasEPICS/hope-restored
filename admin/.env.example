# SQLite environment variables
DATABASE_URL = file:./dev.db

# Nuxt.js environment variables
VITE_NUXT_ENV_API_URL = http://localhost:3000
VITE_EXTERNAL_VIEWER_URL = http://localhost:4000

# Better Auth
BETTER_AUTH_URL = http://localhost:3000
BETTER_AUTH_SECRET = change-me-to-a-long-random-secret
BETTER_AUTH_TRUSTED_ORIGINS = http://localhost:3000,http://localhost:4000

# Comma-separated allowlists for role-based access
BETTER_AUTH_ADMIN_EMAILS = admin@example.org
BETTER_AUTH_STAFF_EMAILS = staff@example.org
