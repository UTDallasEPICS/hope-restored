# SQLite environment variables
DATABASE_URL = file:./dev.db

# Nuxt.js environment variables
VITE_NUXT_ENV_API_URL = http://localhost:3000
VITE_EXTERNAL_VIEWER_URL = http://localhost:4000

# Better Auth
BETTER_AUTH_URL = http://localhost:3000
BETTER_AUTH_SECRET = change-me-to-a-long-random-secret
# Optional extra origins (comma-separated). LAN IPs (192.168.x.x) are allowed automatically in dev when using npm run dev -- --host
BETTER_AUTH_TRUSTED_ORIGINS = http://localhost:3000,http://localhost:4000
# Comma-separated allowlist (optional). Users with role staff/admin in the DB also get access.
# BETTER_AUTH_ADMIN_EMAILS = you@example.com
# BETTER_AUTH_STAFF_EMAILS = teammate@example.com

# #Node Mailer
SMTP_USER='Some@Email.com'
SMTP_PASS='SMTP pass word here'
SMTP_FROM= 'Some@Email.com'
